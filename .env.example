# Food Delivery Route Optimizer — Environment Configuration
# Copy this file to .env and fill in your values.

# ── Backend ──────────────────────────────────────────────────
# Port for the FastAPI server (default: 8000)
BACKEND_PORT=8000

# Host for the FastAPI server (default: 0.0.0.0 for all interfaces)
BACKEND_HOST=0.0.0.0

# ── Frontend ─────────────────────────────────────────────────
# URL of the FastAPI backend (used by the React frontend)
VITE_API_URL=http://localhost:8000

# WebSocket URL of the backend
VITE_WS_URL=ws://localhost:8000/ws

# ── OSMnx / OpenStreetMap ────────────────────────────────────
# Request timeout in seconds for downloading road network data
OSM_TIMEOUT=180

# ── Simulation Defaults ──────────────────────────────────────
DEFAULT_NUM_ORDERS=1000
DEFAULT_NUM_DRIVERS=50
DEFAULT_CITY=Pune, India
